import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns


df = pd.read_excel("Demo.xlsx")


df.head()


df.info()


df.describe()


df.isnull().sum()


df['%'].fillna(df['%'].mean(), inplace=True)


df.isnull().sum()


df['UT 1 Marks'].fillna(df['UT 1 Marks'].mean(), inplace=True)


df.isnull().sum()


df['%.1'].fillna(df['%.1'].mean(), inplace=True)


df.isnull().sum()


df['50% maks of Previous Year SPPU Result'].fillna(df['50% maks of Previous Year SPPU Result'].mean(), inplace=True)


df.isnull().sum()


df.dtypes


num_cols = df.select_dtypes(include='number').columns


num_cols


plt.figure(figsize=(10,6))
df[num_cols].boxplot()
plt.xticks(rotation=45)
plt.title("Boxplot for Outlier Detection")
plt.show()


sns.scatterplot(x='UT 1 Marks', y='50% maks of Previous Year SPPU Result',data=df)
plt.show()


df['Log_Marks'] = np.log10(df['UT 1 Marks'])


df['Log_Marks'].plot(kind='hist',title='Log-Transformed UT 1 Marks')
plt.show()



